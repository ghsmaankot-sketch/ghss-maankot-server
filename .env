# ============================================================
#  GHSS MAANKOT — Environment Variables
#  Is file ko copy karke naam .env rakho, phir values bharo
# ============================================================

# ── MongoDB Atlas ─────────────────────────────────────────
# Atlas → Connect → Drivers → Copy connection string
# apna username:password wahan dalo
MONGODB_URI=mongodb://ghsmaankot_db_user:9yZVehpfUZkyrtDc@ac-vi61ood-shard-00-00.wkrldwj.mongodb.net:27017,ac-vi61ood-shard-00-01.wkrldwj.mongodb.net:27017,ac-vi61ood-shard-00-02.wkrldwj.mongodb.net:27017/?ssl=true&replicaSet=atlas-wpmfuh-shard-0&authSource=admin&appName=Cluster0

# ── Google Drive (public shareable link se file ID lo) ────
# Drive mein index.html rakho → Share → Anyone with link
# URL: https://drive.google.com/file/d/FILE_ID/view
# Bas FILE_ID copy karo neeche
GDRIVE_HTML_FILE_ID=1pLnx9e7eD3gPrmge8cZ6OtLltdx4_JKf

# ── Google Drive Backup Folder ────────────────────────────
# Drive mein "GHSS_Backups" folder banao
# Folder URL: https://drive.google.com/drive/folders/FOLDER_ID
# Sirf FOLDER_ID copy karo
GDRIVE_BACKUP_FOLDER_ID=1dCSFdvKkBzPwCsAkXAGhknmhalqE1etH

# ── Google Service Account (Backup ke liye) ───────────────
# Google Cloud Console → Service Account → JSON key download karo
# Us JSON file ka content yahan paste karo (single line mein)
# Ya file ka path de sakte ho:
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Server ────────────────────────────────────────────────
PORT=3000
SCHOOL_PREFIX=GHSS-MAANKOT

# ── Cache setting ─────────────────────────────────────────
# Drive se HTML kitni seconds baad dobara fetch hogi
# 0 = har baar fresh (slow), 30 = 30 second cache (recommended)
HTML_CACHE_SECONDS=30
